{
  "displayName": "Planna: Cloud Run 5xx response detected",
  "documentation": {
    "content": "Triggered when planna emits any 5xx response in the last 5 minutes. Most often this is a backend exception (Anthropic timeout, Firestore unavailable) or a misconfigured deploy. Inspect logs with:\n\n  gcloud run services logs read planna --region=asia-northeast3 --limit=50\n",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "5xx rate > 0 over 5m",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.labels.service_name=\"planna\" metric.labels.response_code_class=\"5xx\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "enabled": true
}
