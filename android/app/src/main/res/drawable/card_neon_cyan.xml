<?xml version="1.0" encoding="utf-8"?>
<!--
  Stat card backdrop. Translucent cyan fill + solid neon stroke fakes a
  glow against the pitch-black surface behind it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/neon_cyan_dim" />
    <stroke android:width="1dp" android:color="@color/neon_cyan" />
    <corners android:radius="6dp" />
</shape>
