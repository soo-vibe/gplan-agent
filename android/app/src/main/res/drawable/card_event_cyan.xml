<?xml version="1.0" encoding="utf-8"?>
<!--
  Event card with left neon stripe. Stripe ID/channel color identifies
  the source (cyan = SMS). LayerList lets us reuse a single dark surface
  with a 2dp colored left edge.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface" />
            <stroke android:width="1dp" android:color="@color/stroke_subtle" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:width="2dp" android:gravity="left">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_cyan" />
        </shape>
    </item>
</layer-list>
