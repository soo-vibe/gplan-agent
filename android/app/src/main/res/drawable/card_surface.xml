<?xml version="1.0" encoding="utf-8"?>
<!--
  Default event/list card backdrop. Dark surface with subtle stroke.
  Combined with card_event_*.xml left stripes for channel coding.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bg_surface" />
    <stroke android:width="1dp" android:color="@color/stroke_subtle" />
    <corners android:radius="6dp" />
</shape>
