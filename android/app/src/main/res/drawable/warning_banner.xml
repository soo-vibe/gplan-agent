<?xml version="1.0" encoding="utf-8"?>
<!-- Top-of-screen warning banner when permissions are missing. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/status_warning_bg" />
    <stroke android:width="1dp" android:color="@color/status_warning_fg" />
    <corners android:radius="6dp" />
</shape>
