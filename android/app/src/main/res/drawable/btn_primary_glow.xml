<?xml version="1.0" encoding="utf-8"?>
<!--
  Primary CTA button background. Cyan→magenta gradient with rounded
  corners. Used as the login button and the onboarding "시작하기" button.
  Text on top should be bg_void (near-black) for max contrast.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/neon_cyan"
        android:endColor="@color/neon_magenta" />
    <corners android:radius="8dp" />
</shape>
