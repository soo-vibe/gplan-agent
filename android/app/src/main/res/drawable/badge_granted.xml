<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill badge for permission cards in granted state. Translucent neon-green
  fill + solid border to read clearly against dark card surfaces.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/status_ok_bg" />
    <stroke android:width="1dp" android:color="@color/status_ok_fg" />
    <corners android:radius="20dp" />
</shape>
