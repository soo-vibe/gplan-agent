<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_void">

    <!-- Brand mark: cyan→magenta gradient block holding the wordmark
         initial. Sized larger than the in-app mark to dominate the
         landing screen. -->
    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/logo_gradient"
        android:gravity="center"
        android:text="P"
        android:textColor="@color/bg_void"
        android:textSize="40sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PLANNA"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI SCHEDULE AGENT"
        android:textSize="11sp"
        android:textColor="@color/neon_cyan"
        android:fontFamily="monospace"
        android:letterSpacing="0.25"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SMS · 카카오톡 · Gmail에서\n일정을 자동으로 등록합니다"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:layout_marginBottom="56dp" />

    <!-- Cached account hint, shown only when GoogleSignIn has a prior
         account (i.e., re-auth flow). -->
    <TextView
        android:id="@+id/tvLoginEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- Primary CTA: cyan→magenta gradient. Text uses bg_void for max
         contrast against the bright gradient. We set backgroundTint=null
         so our drawable wins; ripple is preserved via rippleColor. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Google로 로그인"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/bg_void"
        android:paddingVertical="14dp"
        android:background="@drawable/btn_primary_glow"
        app:backgroundTint="@null"
        app:cornerRadius="0dp"
        app:rippleColor="#33000000" />

    <TextView
        android:id="@+id/tvLoginStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="monospace"
        android:layout_marginTop="24dp"
        android:gravity="center" />

</LinearLayout>
